{
  "name": "whmcs-mcp-server",
  "version": "1.2.0",
  "description": "MCP Server for managing WHMCS installations - clients, products, billing, tickets, domains, and integrations",
  "type": "module",
  "main": "dist/index.js",
  "authors": [
    "scarecr0w12"
  ],
  "bin": {
    "whmcs-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "tsx src/test.ts",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "docker:build": "docker build -t whmcs-mcp-server .",
    "docker:run": "docker run -it --rm --env-file .env whmcs-mcp-server"
  },
  "keywords": [
    "whmcs",
    "mcp",
    "model-context-protocol",
    "hosting",
    "billing",
    "docker",
    "automation",
    "api",
    "web-hosting",
    "support-tickets",
    "domain-management"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scarecr0w12/whmcs-mcp-tool.git"
  },
  "bugs": {
    "url": "https://github.com/scarecr0w12/whmcs-mcp-tool/issues"
  },
  "homepage": "https://github.com/scarecr0w12/whmcs-mcp-tool#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^17.2.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
