{
  "name": "@mohn93/whmcs-mcp",
  "version": "1.2.0",
  "description": "MCP Server for managing WHMCS installations - clients, products, billing, tickets, domains, and integrations",
  "type": "module",
  "main": "dist/index.js",
  "author": "Mohanned Binmiskeen",
  "contributors": [
    "scarecr0w12 (original author of whmcs-mcp-tool)"
  ],
  "bin": {
    "whmcs-mcp": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "tsx src/test.ts",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "docker:build": "docker build -t whmcs-mcp-server .",
    "docker:run": "docker run -it --rm --env-file .env whmcs-mcp-server",
    "capture": "tsx test/scripts/capture-fixtures.ts"
  },
  "keywords": [
    "whmcs",
    "mcp",
    "model-context-protocol",
    "hosting",
    "billing",
    "docker",
    "automation",
    "api",
    "web-hosting",
    "support-tickets",
    "domain-management"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mohn93/whmcs-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/mohn93/whmcs-mcp/issues"
  },
  "homepage": "https://github.com/mohn93/whmcs-mcp#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^17.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
